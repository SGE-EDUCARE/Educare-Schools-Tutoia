generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  password_hash String
  role          String
  active              Boolean      @default(true)
  must_reset_password Boolean      @default(true)
  created_at          DateTime     @default(now())
  lesson_plans        LessonPlan[]
  allocations         TeacherAllocation[] @relation("TeacherAllocations")
  messages_recv       Message[]    @relation("ReceivedMessages")
  messages_sent Message[]    @relation("SentMessages")
  children      Student[]    @relation("ParentStudents")
  daily_routines DailyRoutine[]

  @@map("users")
}

model Student {
  id              String       @id @default(uuid())
  name            String
  registration_id String       @unique
  education_level String
  grade_name      String
  photo_url       String?
  
  // Novos Campos
  address         String?
  phone           String?
  document        String?      // RG ou Certidão
  birth_date      String?      // Usaremos string para facilitar o input HTML date mas pode ser DateTime
  naturalness     String?      // Cidade/UF
  cpf             String?
  nis             String?
  father_name     String?
  mother_name     String?
  scholarship     Boolean      @default(false)

  class_id        String?
  parent_id       String?
  attendances     Attendance[]
  grades          Grade[]
  daily_routines  DailyRoutine[]
  class           Class?       @relation(fields: [class_id], references: [id])
  parent          User?        @relation("ParentStudents", fields: [parent_id], references: [id])

  @@map("students")
}

model AcademicLevel {
  id          String   @id @default(uuid())
  name        String   @unique // ex: Ensino Fundamental I
  grades      AcademicGrade[]
  @@map("academic_levels")
}

model AcademicGrade {
  id          String   @id @default(uuid())
  name        String   // ex: 1º Ano
  level_id    String
  level       AcademicLevel @relation(fields: [level_id], references: [id], onDelete: Cascade)
  classes     Class[]
  @@map("academic_grades")
}

model AcademicTurn {
  id          String   @id @default(uuid())
  name        String   @unique // ex: Matutino, Vespertino, Integral
  classes     Class[]
  @@map("academic_turns")
}

model Class {
  id              String       @id @default(uuid())
  name            String       // ex: Turma A
  grade_id        String
  grade           AcademicGrade @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  turn_id         String
  turn            AcademicTurn  @relation(fields: [turn_id], references: [id], onDelete: Cascade)
  
  homeworks       Homework[]
  lesson_plans    LessonPlan[]
  schedules       Schedule[]
  students        Student[]
  allocations     TeacherAllocation[]

  @@map("classes")
}

model Schedule {
  id          String @id @default(uuid())
  day_of_week Int
  time_start  String
  time_end    String
  subject     String
  class_id    String
  class       Class  @relation(fields: [class_id], references: [id])

  @@map("schedules")
}

model LessonPlan {
  id                    String      @id @default(uuid())
  date                  DateTime
  subject               String?
  bimester              Int?
  month                 String?
  general_competencies  String?     @db.Text
  specific_competencies String?     @db.Text
  knowledge_objects     String?     @db.Text
  programmatic_content  String?     @db.Text
  skills                String?     @db.Text // Texto livre (legado ou custom)
  bncc_skills           BnccSkill[] @relation("LessonPlanBnccSkills")
  methodology           String?     @db.Text
  evaluation            String?     @db.Text
  resources             String?     @db.Text
  references            String?     @db.Text
  content               String?     @db.Text
  status                String      @default("PENDING")
  type                  String?     @default("Mensal")
  teacher_id            String
  class_id              String
  class                 Class       @relation(fields: [class_id], references: [id])
  teacher               User        @relation(fields: [teacher_id], references: [id])

  @@map("lesson_plans")
}

model BnccSkill {
  id           String       @id @default(uuid())
  code         String       @unique // ex: EF09LP04
  description  String       @db.Text
  subject      String?
  level        String?
  lesson_plans LessonPlan[] @relation("LessonPlanBnccSkills")

  @@map("bncc_skills")
}

model Attendance {
  id         String   @id @default(uuid())
  date       DateTime
  present    Boolean
  student_id String
  class_id   String
  student    Student  @relation(fields: [student_id], references: [id])

  @@map("attendances")
}

model Grade {
  id               String  @id @default(uuid())
  bimester         Int
  subject          String?
  label            String? // ex: 1ª Prova, 2ª Prova
  value            Float?
  qualitative_text String?
  student_id       String
  student          Student @relation(fields: [student_id], references: [id])

  @@map("grades")
}

model Homework {
  id          String   @id @default(uuid())
  title       String
  description String
  due_date    DateTime
  class_id    String
  class       Class    @relation(fields: [class_id], references: [id])

  @@map("homeworks")
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String
  target_role String?
  class_id    String?
  created_at  DateTime @default(now())

  @@map("notices")
}

model Message {
  id          String   @id @default(uuid())
  content     String
  read        Boolean  @default(false)
  created_at  DateTime @default(now())
  sender_id   String
  receiver_id String
  receiver    User     @relation("ReceivedMessages", fields: [receiver_id], references: [id], onDelete: Cascade)
  sender      User     @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model TeacherAllocation {
  id         String   @id @default(uuid())
  teacher_id String
  class_id   String
  subject    String?  // Nulo para polivalentes (Infantil/Fund I)
  teacher    User     @relation("TeacherAllocations", fields: [teacher_id], references: [id], onDelete: Cascade)
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)

  @@map("teacher_allocations")
}

model DailyRoutine {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  food       String?  // Tudo, Parcial, Nada
  sleep      Boolean  @default(false)
  hygiene    String?  // Troca de Fralda, Banho, etc
  obs        String?
  student_id String
  teacher_id String
  
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  teacher    User     @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  
  @@map("daily_routines")
}
